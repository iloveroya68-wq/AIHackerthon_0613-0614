# Database
POSTGRES_DB=drift
POSTGRES_USER=drift
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_URL=redis://localhost:6379/0

# Django
DJANGO_SECRET_KEY=change_me_to_a_random_50_char_string
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# L4 briefing
OPENAI_API_KEY=
GMS_OPENAI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_OPENAI_MODEL=gpt-4.1

# Live public marine data. The shared key is used unless an override is set.
DATA_GO_KR_API_KEY=
KHOA_API_KEY=
KMA_API_KEY=

# AWS report storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=drift-reports
AWS_REGION=ap-northeast-2

# Prediction engine
DRIFT_ENGINE=real
DRIFT_L2_ENGINE=opendrift
ENGINE_PARTICLE_COUNT=1000
ENGINE_L3_MIN_TRAINING_RECORDS=30
DRIFT_SEED_RADIUS_M=500
DRIFT_RANDOM_SEED=42
DRIFT_MODEL_PATH=/engine/artifacts/l3_correction.joblib
DRIFT_MODEL_METADATA_PATH=/engine/artifacts/model_metadata.json

# historical: local bundle; live: backend KMA/KHOA integrations
DRIFT_DATA_SOURCE=historical
DRIFT_DATA_ROOT=/data/modeling_inputs
DRIFT_DATA_HOST_PATH=./data/modeling_inputs
