/DRIFT-FrontUpdate/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.cover
.coverage
htmlcov/
.tox/

# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# --- Docker ---
docker-data/
postgres_data/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

